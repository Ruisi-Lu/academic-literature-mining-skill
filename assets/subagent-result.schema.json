{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/academic-literature-mining/subagent-result.schema.json",
  "title": "Academic search worker candidate",
  "description": "Emit one object per NDJSON line.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "query",
    "source",
    "title",
    "evidence_urls",
    "discovered_at"
  ],
  "anyOf": [
    {
      "required": ["doi"]
    },
    {
      "required": ["arxiv_id"]
    },
    {
      "required": ["openalex_id"]
    }
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "query": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "doi": {
      "type": "string",
      "pattern": "^10\\.[0-9]{4,9}/\\S+$"
    },
    "arxiv_id": {
      "type": "string",
      "pattern": "^(?:[0-9]{4}\\.[0-9]{4,5}|[A-Za-z][A-Za-z0-9.-]*/[0-9]{7})(?:v[0-9]+)?$"
    },
    "openalex_id": {
      "type": "string",
      "pattern": "^(https://openalex\\.org/)?[Ww][0-9]+$"
    },
    "landing_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "evidence_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "discovered_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
