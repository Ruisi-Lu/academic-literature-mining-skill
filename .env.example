# Required for NVIDIA Build hosted inference. Get it at
# https://build.nvidia.com/settings/api-keys and never commit the real key.
NVIDIA_API_KEY=
NEMOTRON_EMBED_MODEL_ID=nvidia/llama-nemotron-embed-vl-1b-v2
NEMOTRON_RERANK_MODEL_ID=nvidia/llama-nemotron-rerank-vl-1b-v2
NVIDIA_EMBED_URL=https://integrate.api.nvidia.com/v1/embeddings
NVIDIA_RERANK_URL=https://ai.api.nvidia.com/v1/retrieval/nvidia/llama-nemotron-rerank-vl-1b-v2/reranking

# OpenAlex key: https://openalex.org/settings/api
# CONTACT_EMAIL is required when Crossref is selected; it is not a token.
OPENALEX_API_KEY=
CONTACT_EMAIL=

# Optional enrichment; ask the user before enabling it. Request a key at
# https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# Prebuilt CLI image. Keep this version equal to the published v-prefixed GitHub Release without
# the leading "v". On Linux, set the UID/GID to `id -u` and `id -g` if they are not 1000.
LITMINE_IMAGE=ghcr.io/ruisi-lu/academic-literature-mining-skill
LITMINE_VERSION=0.1.1
LITMINE_UID=1000
LITMINE_GID=1000

# Qdrant is bound to localhost by docker-compose.yml. Generate this local secret
# yourself (for example, `openssl rand -hex 32`); no vendor token is issued.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=academic_literature_v1
QDRANT_VECTOR_SIZE=2048

# Network and batch controls.
HTTP_TIMEOUT_SECONDS=60
DOWNLOAD_WORKERS=4
NVIDIA_EMBED_BATCH_SIZE=4
NVIDIA_RERANK_BATCH_SIZE=32
MAX_PDF_MIB=200
PDF_RENDER_DPI=144
PDF_JPEG_QUALITY=85

# Keep the native PDFium cache with the installed skill instead of relying on a writable home.
PDFIUM_AUTO_CACHE_DIR=.cache/pdfium
